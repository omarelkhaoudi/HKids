# Frontend environment (Vite)
# Copy to .env.local for local builds.

# Required for Android / Capacitor production builds.
VITE_API_URL=https://your-backend.example.com

# Kiosk idle reset in milliseconds. 0 disables auto-return to /kids.
VITE_ANDROID_KIOSK_IDLE_MS=600000

# Sentry error monitoring (optional — disabled when VITE_SENTRY_DSN is empty)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2
VITE_SENTRY_REPLAYS_SAMPLE_RATE=0.1
