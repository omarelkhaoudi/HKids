# Port for the backend server
PORT=3000

# Environment (development, production)
NODE_ENV=development

# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=hkids-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# CORS Origin (frontend URL)
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Stripe Checkout subscriptions
# Create a restricted/live secret key in Stripe Dashboard for production.
STRIPE_SECRET_KEY=

# Newsletter confirmation emails
RESEND_API_KEY=
# Optional aliases accepted by the backend: RESEND_KEY, RESEND_FROM_EMAIL, EMAIL_FROM
# Use a sender from a verified Resend domain in production.
NEWSLETTER_FROM_EMAIL=HKids <newsletter@your-domain.com>
# Temporary free testing only: allows HKids <onboarding@resend.dev>
ALLOW_RESEND_TEST_SENDER=false
# Public backend URL used inside emails. Prefer the stable project domain, not a protected preview URL.
PUBLIC_BACKEND_URL=https://h-kids-dfu3.vercel.app
BACKEND_URL=http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Production file storage (required for Vercel/serverless runtime uploads)
# Create a public Supabase Storage bucket and set its name here.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=hkids-books

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

# AI provider abstraction
# Supported values: openai, gemini, anthropic
AI_PROVIDER=openai
# Optional when the main provider does not support audio (for example Anthropic).
AI_TRANSCRIPTION_PROVIDER=openai
AI_TIMEOUT_MS=20000
AI_MAX_RETRIES=2
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MAX_RETRIES=2
OPENAI_CACHE_TTL_MS=300000
OPENAI_MAX_CACHE_ENTRIES=200
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_VERSION=2023-06-01

# Voice provider abstraction
# Supported values for now: mock, elevenlabs
VOICE_PROVIDER=mock
VOICE_TIMEOUT_MS=15000
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_MAX_RETRIES=2

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/hkids
# Neon/Supabase/Render example:
# DATABASE_URL=postgresql://user:password@xxxxxx.neon.tech/dbname?sslmode=require

