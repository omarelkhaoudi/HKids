{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "frontend/src/**/*.js",
    "frontend/src/**/*.jsx",
    "backend/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "frontend/dist",
    "frontend/android",
    "backend/uploads",
    "backend/scripts"
  ]
}
